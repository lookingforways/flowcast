# ─── Required ────────────────────────────────────────────────────────────────
RSS_FEED_URL=https://your-podcast.com/feed.xml

# Google OAuth2 credentials (YouTube Data API v3)
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# ─── Optional (with defaults) ─────────────────────────────────────────────────
# Full automatic pipeline: download → render → publish on new episodes
FLOWCAST_AUTO_PUBLISH=false

# How often to check the RSS feed for new episodes (minutes)
POLL_INTERVAL_MINUTES=60

# YouTube video privacy when publishing
# Options: public | unlisted | private
YOUTUBE_PRIVACY=unlisted

# YouTube category ID (22 = People & Blogs)
YOUTUBE_CATEGORY_ID=22

# Delete rendered MP4s older than N days to save disk space (0 = never)
MAX_RENDER_AGE_DAYS=30

# Data directory (absolute path inside the container)
DATA_DIR=/app/data

# Secret key for session signing — generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-random-string

# Authentication
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password
# SESSION_MAX_AGE=604800  # 7 days in seconds (default)

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Host URL for OAuth2 callback (no trailing slash)
# Use your actual domain in production
APP_BASE_URL=http://localhost:8000

# Security contact email (shown in /.well-known/security.txt)
SECURITY_CONTACT=security@your-domain.com
